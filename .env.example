PORT=5000
DATABASE_URL=postgresql://user:password@host:5432/medications_delivery
JWT_SECRET=your_very_long_jwt_secret_here
JWT_EXPIRES_IN=7d
CLIENT_URL=https://your-frontend.netlify.app

# Noor Express delivery
NOOR_HOST=https://tback.noor.uz
