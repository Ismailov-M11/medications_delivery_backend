# Seed credentials — set these on Railway before first deploy
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password_here
SEED_PHARMACY_LOGIN=pharmacy
SEED_PHARMACY_PASSWORD=your_pharmacy_password_here
