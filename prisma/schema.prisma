generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Pharmacy {
  id                   String                @id @default(cuid())
  name                 String
  ownerName            String?
  email                String?
  address              String?
  phone                String
  lat                  Float?
  lng                  Float?
  login                String                @unique
  password             String
  isActive             Boolean               @default(true)
  requiresLocation     Boolean               @default(false)
  subscriptionExpiry   DateTime?
  allowedCouriers      String                @default("yandex,noor,millennium")
  createdAt            DateTime              @default(now())
  orders               Order[]
  subscriptionPayments SubscriptionPayment[]
}

model SubscriptionPayment {
  id         String    @id @default(cuid())
  pharmacyId String
  pharmacy   Pharmacy  @relation(fields: [pharmacyId], references: [id])
  invoiceId  String    @unique
  amount     Int
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  paidAt     DateTime?
}

model Order {
  id              String      @id @default(cuid())
  token           String      @unique
  pharmacyId      String
  pharmacy        Pharmacy    @relation(fields: [pharmacyId], references: [id])
  status          OrderStatus @default(pending)
  pharmacyComment String?
  medicinesTotal  Float    @default(0)

  customerName    String?
  customerPhone   String?
  customerAddress String?
  apartment       String?
  entrance        String?
  floor           String?
  intercom        String?
  customerComment String?
  customerLat     Float?
  customerLng     Float?

  selectedCourier CourierType?
  deliveryPrice   Float?
  trackingUrl     String?
  totalPrice      Float?
  noorOrderId        Int?
  millenniumOrderId  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  pending
  awaiting_confirmation
  confirmed
  courier_pickup
  courier_picked
  courier_delivery
  delivered
  cancelled
}

enum CourierType {
  yandex
  noor
  millennium
}
